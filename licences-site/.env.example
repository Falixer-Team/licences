# Cloudflare account and D1 database identifiers.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=

# Cloudflare API token with D1 Edit permission for the selected account.
CLOUDFLARE_D1_API_TOKEN=

# Long random secret used by POST/PATCH/DELETE /admin/licenses.
ADMIN_API_KEY=

# Comma-separated origins allowed to call GET /query from browsers.
CORS_ALLOWED_ORIGINS=https://falixer.dev,http://localhost:3000
