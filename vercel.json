{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "pnpm build",
  "outputDirectory": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index?route=health" },
    { "source": "/query", "destination": "/api/index?route=query" },
    { "source": "/admin/licenses", "destination": "/api/index?route=admin" },
    { "source": "/admin/licenses/:id", "destination": "/api/index?route=admin&id=:id" }
  ]
}
